{
  "version": 1,
  "defaultBaseUrl": "http://localhost:3000",
  "probes": [
    {
      "id": "health",
      "name": "API health",
      "request": {
        "method": "GET",
        "path": "/v1/health"
      },
      "expect": {
        "status": 200
      }
    },
    {
      "id": "login-student",
      "name": "Login as student",
      "request": {
        "method": "POST",
        "path": "/v1/auth/login",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "email": "student@attendly.edu.vn",
          "password": "dev-password"
        }
      },
      "capture": {
        "token": "$.data.accessToken"
      },
      "expect": {
        "status": 200
      }
    },
    {
      "id": "me-student",
      "name": "Read authenticated actor context",
      "request": {
        "method": "GET",
        "path": "/v1/me",
        "headers": {
          "Authorization": "Bearer {{token}}"
        }
      },
      "expect": {
        "status": 200
      }
    }
  ]
}
