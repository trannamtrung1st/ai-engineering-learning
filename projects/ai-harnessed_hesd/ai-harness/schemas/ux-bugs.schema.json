{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://attendly.local/ai-harness/schemas/ux-bugs.schema.json",
  "title": "HarnessUxBugs",
  "type": "object",
  "required": ["sliceId", "runId", "generatedAt", "bugs"],
  "additionalProperties": false,
  "properties": {
    "sliceId": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "bugs": {
      "type": "array",
      "items": { "$ref": "#/$defs/uxBug" }
    }
  },
  "$defs": {
    "severity": {
      "type": "string",
      "enum": ["P0", "P1", "P2", "P3"]
    },
    "uxBug": {
      "type": "object",
      "required": [
        "id",
        "severity",
        "title",
        "page",
        "screenshot",
        "repro",
        "expected",
        "actual"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^UX-[a-z0-9-]+-[0-9]{3}$"
        },
        "severity": { "$ref": "#/$defs/severity" },
        "title": { "type": "string", "minLength": 1 },
        "page": { "type": "string", "minLength": 1 },
        "screenshot": { "type": "string", "minLength": 1 },
        "repro": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "expected": { "type": "string", "minLength": 1 },
        "actual": { "type": "string", "minLength": 1 },
        "relatedTags": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(AC|FR|BR|NFR)-" }
        }
      }
    }
  }
}
