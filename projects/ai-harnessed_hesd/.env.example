# Dev preview database (docker-compose.yml db service)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app
API_PORT=3001
WEB_PORT=3000
AIH_PREVIEW_WEB_PORT=3007

# Cache (docker-compose.yml redis service)
REDIS_URL=redis://localhost:6379

# Ephemeral test stack (docker-compose.test.yml) — harness overrides DATABASE_URL during integration/e2e
TEST_POSTGRES_PORT=5433
TEST_DATABASE_URL=postgresql://attendly:attendly@localhost:5433/attendly_test
TEST_REDIS_URL=redis://localhost:6380
TEST_S3_ENDPOINT=http://localhost:9002

# API runtime (local / compose)
JWT_SECRET=local-dev-secret-change-me
QR_TOKEN_TTL_SECONDS=30
DEFAULT_GPS_RADIUS_METERS=100
LOG_LEVEL=debug
SEED_ENABLED=true

# Web (Vite)
VITE_API_BASE_URL=http://localhost:3001
VITE_APP_NAME=Attendly
VITE_LOCALE_DEFAULT=vi-VN
