{
  "name": "@attendly/web",
  "version": "0.1.0",
  "private": true,
  "description": "Attendly web client — React + Vite",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "prebuild": "npm run build -w @attendly/domain --if-present",
    "preview": "vite preview",
    "typecheck": "npm run build -w @attendly/domain && tsc -p tsconfig.json --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@attendly/domain": "*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@attendly/config": "*",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
