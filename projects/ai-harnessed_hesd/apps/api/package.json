{
  "name": "@attendly/api",
  "version": "0.1.0",
  "private": true,
  "description": "Attendly HTTP API — Node.js + Fastify",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prebuild": "npm run build -w @attendly/domain --if-present",
    "dev": "node --watch dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "npm run build -w @attendly/domain && tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test:unit": "npm run build -w @attendly/domain && vitest run --config vitest.unit.config.ts",
    "test:integration": "npm run build -w @attendly/domain && vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@attendly/domain": "*",
    "fastify": "^5.2.0",
    "pg": "^8.13.1",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@attendly/config": "*",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
