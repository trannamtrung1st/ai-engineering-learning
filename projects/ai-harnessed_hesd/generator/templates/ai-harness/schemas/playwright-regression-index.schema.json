{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://{{PRODUCT_SLUG}}.local/ai-harness/schemas/playwright-regression-index.schema.json",
  "title": "PlaywrightRegressionIndex",
  "type": "object",
  "required": ["slices"],
  "additionalProperties": false,
  "properties": {
    "slices": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/sliceEntry" }
    }
  },
  "$defs": {
    "sliceEntry": {
      "type": "object",
      "required": ["specPath", "lastRunId", "testCount", "sourceTcIds"],
      "additionalProperties": false,
      "properties": {
        "specPath": { "type": "string", "minLength": 1 },
        "lastRunId": { "type": ["string", "null"] },
        "testCount": { "type": "integer", "minimum": 0 },
        "sourceTcIds": {
          "type": "array",
          "items": { "type": "string", "pattern": "^TC-" }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
