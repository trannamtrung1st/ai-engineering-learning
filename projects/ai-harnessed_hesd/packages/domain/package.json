{
  "name": "@attendly/domain",
  "version": "0.1.0",
  "private": true,
  "description": "Shared DTOs, error codes, and API contract types for Attendly",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test:unit": "vitest run --config vitest.config.ts"
  },
  "devDependencies": {
    "@attendly/config": "*",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
