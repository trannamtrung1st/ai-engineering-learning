      ],
      "coverageHints": [
        "integration: instructor report scoped to assigned class-subject pairs only",
        "rbac-negative: unassigned instructor receives 403 on report endpoint",
        "e2e: admin institution-wide report returns all cohorts within date filter"
      ]
    },
    {
      "match": "^AC-13$",
      "docs": [
        "docs/technical/05-api-design.md",
        "docs/brds/04-business-rules.md",
        "docs/ui-ux/09-page-list.md"
      ],
      "coverageHints": [
        "integration: CSV export columns match spec; export action audit-logged",
        "rbac-negative: instructor and student export requests rejected with localized message",
        "e2e: admin CSV download succeeds with filtered report scope"
      ]
    },
    {
      "match": "^AC-14$",
      "docs": [
        "docs/technical/05-api-design.md",
        "docs/ui-ux/09-page-list.md"
      ],
      "coverageHints": [
        "integration: student history returns only own records with pagination envelope",
        "rbac-negative: student cannot access peer attendance via API",
        "browser-journey: /history shows paginated list with status badges"
      ]
    },
    {
      "match": "^AC-1[56]$",
      "docs": [
        "docs/technical/05-api-design.md",
        "docs/ui-ux/10-user-flows.md",
        "docs/technical/01-roles-permissions.md"
      ],
      "coverageHints": [
        "integration: session monitor poll returns updated present/absent counts",
        "browser-journey: instructor monitor dashboard refreshes within 5 seconds",
        "e2e: absence threshold notification fires when unexcused rate exceeds 20%"
      ]
