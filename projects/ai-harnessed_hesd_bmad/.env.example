# Public (safe for browser bundles)
# Find these in Supabase Dashboard → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- API only (never prefix with NEXT_PUBLIC_) ---
# Copy these to api/.env when running the API outside Docker, or rely on docker-compose defaults.

# Postgres connection for Drizzle (local compose: postgresql://hesd:hesd_dev@localhost:5432/hesd)
DATABASE_URL=

# Service role key: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Local JWT validation secret; hosted Supabase uses JWKS instead (Story 1.3)
SUPABASE_JWT_SECRET=

# API listen port (default 3001)
PORT=3001

# CORS origin for the Next.js web app
WEB_ORIGIN=http://localhost:3000
