# Copy to .env and adjust for local development. Do not commit secrets.

# PostgreSQL (Docker Compose db service — development mode)
DATABASE_URL=postgresql://we_event:we_event@localhost:5432/we_event

# API
PORT=3001
JWT_SECRET=change-me-local-only
TIMEZONE=UTC
DEV_AUTH_ENABLED=true

# Web (local dev)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Optional seed toggle for local fixtures
SEED_ENABLED=false
