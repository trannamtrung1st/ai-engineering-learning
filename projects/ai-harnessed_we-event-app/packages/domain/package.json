{
  "name": "@we-event/domain",
  "version": "0.1.0",
  "private": true,
  "description": "Shared domain enums, state machines, and validation identifiers (@we-event/domain workspace)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build": "tsc",
    "test:unit": "node --import tsx --test --test-concurrency=1 'src/**/*.test.ts'",
    "test": "npm run test:unit"
  },
  "devDependencies": {
    "@we-event/config": "*",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
