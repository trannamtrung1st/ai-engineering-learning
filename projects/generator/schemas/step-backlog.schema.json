{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["steps"],
  "properties": {
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "passes", "priority", "phase", "kind"],
        "properties": {
          "id": { "type": "string" },
          "passes": { "type": "boolean" },
          "priority": { "type": "integer" },
          "phase": { "type": "integer" },
          "kind": { "enum": ["agent", "gate", "scaffold"] },
          "agent": { "type": "string" },
          "description": { "type": "string" },
          "outputs": { "type": "array", "items": { "type": "string" } },
          "contextDocs": { "type": "array", "items": { "type": "string" } },
          "validators": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
