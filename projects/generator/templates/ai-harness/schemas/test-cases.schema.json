{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://we-event.local/ai-harness/schemas/test-cases.schema.json",
  "title": "HarnessTestCases",
  "type": "object",
  "required": ["productItemId", "version", "docFingerprint", "generatedAt", "cases"],
  "additionalProperties": false,
  "properties": {
    "productItemId": { "type": "string", "pattern": "^(AC|FR|BR|NFR)-" },
    "version": { "type": "integer", "minimum": 1 },
    "docFingerprint": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/testCase" }
    }
  },
  "$defs": {
    "technique": {
      "type": "string",
      "enum": [
        "scenario-matrix",
        "flow-a",
        "flow-b",
        "flow-c",
        "module-integration",
        "http-contract",
        "rbac-negative",
        "pagination",
        "state-transition",
        "browser-journey",
        "concurrency",
        "boundary-error"
      ]
    },
    "testCase": {
      "type": "object",
      "required": [
        "id",
        "category",
        "layer",
        "technique",
        "priority",
        "traceability",
        "title",
        "preconditions",
        "steps",
        "expected",
        "edgeCase"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^TC-" },
        "category": {
          "type": "string",
          "enum": ["functional", "non-functional", "edge"]
        },
        "layer": {
          "type": "string",
          "enum": ["integration", "e2e", "browser"]
        },
        "technique": { "$ref": "#/$defs/technique" },
        "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
        "traceability": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^(AC|FR|BR|NFR)-" }
        },
        "title": { "type": "string", "minLength": 1 },
        "preconditions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "expected": { "type": "string", "minLength": 1 },
        "edgeCase": { "type": "boolean" }
      }
    }
  }
}
