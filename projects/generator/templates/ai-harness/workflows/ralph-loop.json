{
  "loop": {
    "maxIterations": 80,
    "branchPrefix": "aih/",
    "commitOnPass": true,
    "consumeOverrideOnPick": true,
    "autoDeferOutOfSliceCheckFailures": false,
    "generatedRetentionMinutes": 60
  },
  "agent": {
    "timeoutMs": 3600000,
    "idleTimeoutMs": 300000,
    "signalGraceMs": 15000,
    "resultGraceMs": 5000
  },
  "signals": {
    "complete": "COMPLETE",
    "sliceDone": "SLICE_DONE",
    "sliceBlocked": "SLICE_BLOCKED",
    "sliceDefer": "SLICE_DEFER",
    "reviewPass": "REVIEW_PASS",
    "reviewFail": "REVIEW_FAIL",
    "testPass": "BROWSER_TEST_PASS",
    "testFail": "BROWSER_TEST_FAIL"
  },
  "computationalChecks": {
    "playwrightScope": "slice",
    "playwrightFullEveryN": 0,
    "profiles": {
      "fast": ["typecheck", "lint", "test:unit", "test:playwright-ui"],
      "full": ["typecheck", "lint", "build", "test:unit", "test:integration", "test:e2e", "test:playwright-ui"]
    },
    "gateProfile": "full",
    "scopeAllowlist": [],
    "commandTimeoutMs": 600000,
    "commandTimeouts": {
      "typecheck": 300000,
      "lint": 300000,
      "build": 600000,
      "test:unit": 600000,
      "test:integration": 900000,
      "test:e2e": 900000,
      "test:playwright-ui": 900000
    },
    "forbiddenPatterns": [
      {
        "id": "in-memory-map-repo",
        "pattern": "new Map\\(\\).*repository|repository.*new Map\\(\\)",
        "paths": ["apps", "packages"],
        "message": "In-memory Map repository forbidden as system of record"
      },
      {
        "id": "sqlite",
        "pattern": "better-sqlite3|sqlite3",
        "paths": ["apps", "packages"],
        "message": "SQLite forbidden; use Postgres via Docker Compose"
      },
      {
        "id": "mock-fixtures",
        "pattern": "mockItems|MOCK_ITEMS|const (mock)?[Ii]tems = \\[\\s*\\{",
        "paths": ["apps/web/src/app"],
        "message": "Hardcoded fixture arrays forbidden in page components"
      },
      {
        "id": "lorem-ipsum",
        "pattern": "lorem ipsum",
        "paths": ["apps"],
        "message": "Placeholder lorem ipsum content forbidden"
      },
      {
        "id": "demo-data",
        "pattern": "demo-item|Lorem product",
        "paths": ["apps/web"],
        "message": "Demo copy forbidden in production UI"
      }
    ],
    "commands": [
      { "script": "typecheck", "activeWhen": "apps", "optional": false },
      { "script": "lint", "activeWhen": "apps", "optional": false },
      { "script": "build", "activeWhen": "apps", "optional": false },
      { "script": "test:unit", "activeWhen": "apps/api", "optional": false },
      { "script": "test:integration", "activeWhen": "apps/api", "optional": false },
      { "script": "test:e2e", "activeWhen": "tests/e2e", "optional": false },
      { "script": "test:playwright-ui", "activeWhen": "tests/playwright-ui", "optional": true }
    ],
    "runtimeValidation": {
      "db": {
        "strategy": "docker-compose",
        "service": "db",
        "healthTimeoutMs": 60000,
        "requiredBeforeApi": true,
        "activeWhen": "docker-compose.yml"
      },
      "api": {
        "activeWhen": "apps/api",
        "url": "http://localhost:3001/api/v1/health",
        "expectJson": { "status": "ok", "db": "connected" },
        "timeoutMs": 60000
      },
      "web": {
        "activeWhen": "apps/web",
        "url": "http://localhost:3007",
        "expectStatus": 200,
        "timeoutMs": 120000
      },
      "testStack": {
        "composeFile": "docker-compose.test.yml",
        "projectName": "{{PRODUCT_SLUG}}-test",
        "services": ["db"],
        "resetBeforeIntegration": true,
        "activeWhen": "docker-compose.test.yml",
        "healthTimeoutMs": 60000,
        "env": {
          "DATABASE_URL": "postgresql://postgres:postgres@localhost:5433/app_test",
          "TEST_DATABASE_URL": "postgresql://postgres:postgres@localhost:5433/app_test"
        }
      }
    }
  },
  "browserTest": {
    "required": true,
    "playwrightMaxCasesPerSlice": 30,
    "modelKey": "tester",
    "retryFailedCasesFirst": true,
    "activeWhenAgent": ["frontend", "test"],
    "requirePreviewStack": true,
    "previewVerifyGateTimeoutMs": 10000,
    "generatePlaywrightRegression": true,
    "uxBugLogging": true,
    "playwrightOutputDir": "tests/playwright-ui/scenarios",
    "uxBugsDir": "ai-harness/generated/runs/ux-bugs",
    "inputs": [
      "slice-docs",
      "acceptance-tags",
      "checks-report",
      "changed-files",
      "completion-artifacts"
    ]
  },
  "aiReview": {
    "required": true,
    "modelKey": "reviewer",
    "mode": "read-only-static",
    "forbidden": [
      "shell",
      "npm",
      "docker",
      "tests",
      "builds",
      "servers",
      "file-writes"
    ],
    "inputs": [
      "git-diff",
      "changed-files",
      "completion-artifacts",
      "checks-report",
      "browser-test-report",
      "slice-docs"
    ]
  },
  "humanReview": {
    "requiredForMergeReady": true,
    "signal": "HUMAN_REVIEW_PASS"
  },
  "testCaseGate": {
    "mode": "required"
  }
}
